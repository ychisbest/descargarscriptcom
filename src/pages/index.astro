  <!-- Core logic -->
  <script>
    const input = document.getElementById('url-input') as HTMLInputElement;
    const btn = document.getElementById('download-btn') as HTMLButtonElement;
    const errorMsg = document.getElementById('error-msg') as HTMLElement;
    const previewSection = document.getElementById('preview-section') as HTMLElement;
    const previewIframe = document.getElementById('preview-iframe') as HTMLIFrameElement;
    const downloadLink = document.getElementById('download-link') as HTMLAnchorElement;

    function extractId(url: string): string | null {
      const match = url.match(/scribd\.com\/(?:document|doc|presentation|embeds|book|audiobook)\/(\d+)/);
      return match ? match[1] : null;
    }

    function handleDownload() {
      const url = input.value.trim();

      // Reset state
      errorMsg.classList.add('hidden');
      previewSection.classList.add('hidden');

      if (!url) {
        input.focus();
        return;
      }

      const docId = extractId(url);

      if (!docId) {
        errorMsg.classList.remove('hidden');
        return;
      }

      // Generate embed preview URL
      const embedUrl = `https://www.scribd.com/embeds/${docId}/content?start_page=1&view_mode=scroll&show_recommendations=false`;
      previewIframe.src = embedUrl;

      // Generate download URL via third-party API
      const downloadUrl = `https://compress-pdf.vietdreamhouse.com/?fileurl=https://scribd.downloader.tips/pdownload/${docId}/document&title=document`;
      downloadLink.href = downloadUrl;

      // Show preview section
      previewSection.classList.remove('hidden');

      // Scroll to preview
      previewSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    btn.addEventListener('click', handleDownload);

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        handleDownload();
      }
    });

    // Clear error on input
    input.addEventListener('input', () => {
      errorMsg.classList.add('hidden');
    });
  </script>

