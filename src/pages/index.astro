---
import '../styles/global.css';

const siteUrl = 'https://descargarscript.com';
const tools = [
  { title: 'Scripts para automatizar tareas', text: 'Patrones claros para tareas repetitivas en el navegador y el escritorio.', tag: 'Automatización' },
  { title: 'Utilidades para desarrolladores', text: 'Pequeñas herramientas para transformar archivos, comprobar datos y acelerar flujos.', tag: 'Desarrollo' },
  { title: 'Guías de instalación segura', text: 'Aprende a revisar el código y ejecutar scripts con permisos mínimos.', tag: 'Guías' },
];
const faq = [
  ['¿Es seguro descargar scripts?', 'Un script solo es tan fiable como su código y su origen. Revisa el archivo, comprueba el repositorio y evita ejecutar contenido que solicite credenciales o permisos innecesarios.'],
  ['¿Qué necesito para usar un script?', 'Normalmente un navegador moderno, Node.js o Python, según la herramienta. Cada guía indica los requisitos y un ejemplo mínimo para comprobar que funciona.'],
  ['¿Puedo modificar un script?', 'Sí. Los ejemplos están orientados al aprendizaje: léelos, adáptalos a tu caso y conserva una copia antes de hacer cambios.'],
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Descargar Script: guías prácticas, recursos y herramientas para automatizar tareas y trabajar mejor con código." />
    <link rel="canonical" href={siteUrl} />
    <meta property="og:title" content="Descargar Script — recursos prácticos" />
    <meta property="og:description" content="Guías y recursos para trabajar con scripts de forma más segura y eficiente." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta name="twitter:card" content="summary" />
    <title>Descargar Script — recursos prácticos</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org', '@type': 'WebSite', name: 'Descargar Script', url: siteUrl,
      description: 'Recursos y guías prácticas para trabajar con scripts.'
    })} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Descargar Script inicio"><span class="brand-mark">&gt;_</span> Descargar Script</a>
      <nav aria-label="Navegación principal">
        <a href="#recursos">Recursos</a>
        <a href="#como-empezar">Cómo empezar</a>
        <a href="#preguntas">Preguntas</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="eyebrow"><span></span> RECURSOS PARA QUIEN CONSTRUYE</div>
        <h1>Menos tareas repetitivas.<br /><em>Más tiempo para crear.</em></h1>
        <p>Guías prácticas y herramientas sencillas para descubrir, entender y usar scripts con criterio.</p>
        <div class="hero-actions">
          <a class="button primary" href="#recursos">Explorar recursos <span>→</span></a>
          <a class="button subtle" href="#como-empezar">Cómo funciona</a>
        </div>
        <div class="terminal" aria-label="Ejemplo de terminal">
          <div class="terminal-top"><span></span><span></span><span></span><b>guía-inicial.sh</b></div>
          <code><i>$</i> encuentra una tarea repetitiva<br /><i>$</i> entiende el proceso<br /><i>$</i> automatiza paso a paso<br /><strong>✓ listo para ahorrar tiempo</strong></code>
        </div>
      </section>

      <section id="recursos" class="section resources">
        <div class="section-heading"><div><p class="kicker">BIBLIOTECA</p><h2>Elige un punto de partida.</h2></div><p>Contenido breve, directo y pensado para que puedas aplicar lo que aprendes.</p></div>
        <div class="cards">
          {tools.map((tool, index) => <article class="resource-card"><span class="card-number">0{index + 1}</span><p class="tag">{tool.tag}</p><h3>{tool.title}</h3><p>{tool.text}</p><a href="#como-empezar" aria-label={`Ver ${tool.title}`}>Ver guía <span>↗</span></a></article>)}
        </div>
      </section>

      <section id="como-empezar" class="section steps-section">
        <div class="section-heading"><div><p class="kicker">BUENAS PRÁCTICAS</p><h2>Empieza con confianza.</h2></div></div>
        <ol class="steps">
          <li><b>01</b><div><h3>Define el resultado</h3><p>Describe la tarea exacta que quieres reducir. Un objetivo pequeño es más fácil de validar.</p></div></li>
          <li><b>02</b><div><h3>Lee antes de ejecutar</h3><p>Comprueba qué hace cada parte del script, qué datos usa y qué permisos necesita.</p></div></li>
          <li><b>03</b><div><h3>Prueba en un entorno seguro</h3><p>Haz una primera prueba con datos de ejemplo y guarda una copia de tus archivos.</p></div></li>
        </ol>
      </section>

      <section id="preguntas" class="section faq-section">
        <p class="kicker">PREGUNTAS FRECUENTES</p><h2>Lo esencial, sin letra pequeña.</h2>
        <div class="faq-list">{faq.map(([question, answer]) => <details><summary>{question}<span>+</span></summary><p>{answer}</p></details>)}</div>
      </section>
    </main>

    <footer><a class="brand" href="/"><span class="brand-mark">&gt;_</span> Descargar Script</a><p>Recursos prácticos para trabajar mejor con código.</p><div><a href="/privacy/">Privacidad</a><a href="/terms/">Términos</a></div><small>© {new Date().getFullYear()} Descargar Script</small></footer>
  </body>
</html>
